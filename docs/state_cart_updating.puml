@startuml cart_bloc_state_machine
title State Machine - Cart BLoC (CartProvider)

[*] --> Idle

Idle --> Updating : addItem()/removeItem()/updateQty()
Updating --> Updated : success(cart)
Updating --> Error : failure(error)

Updated --> Updating : addItem()/removeItem()/updateQty()
Updated --> Idle : clearCart()

Error --> Updating : retryLastAction()
Error --> Idle : clearError()

@enduml