@startuml payment_bloc_state_machine
title State Machine - Payment BLoC 
[*] --> Idle

Idle --> Initiating : InitiatePayment(orderId, amount)
Initiating --> AwaitingConfirmation : PaymentIntentCreated(clientSecret)

AwaitingConfirmation --> Approved : PaymentSucceeded(txnId)
AwaitingConfirmation --> Declined : PaymentDeclined(code, msg)
AwaitingConfirmation --> Error : PaymentError(msg)

Approved --> [*]
Declined --> [*]
Error --> [*]

@enduml